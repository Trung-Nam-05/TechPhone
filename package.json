{
  "name": "techphone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/src/index.js",
    "server:dev": "nodemon server/src/index.js",
    "seed": "node server/scripts/seedProducts.js",
    "ghtk:cancel-all": "node server/scripts/cancelAllGhtkShipments.js",
    "ghtk:cancel-all:dry": "node server/scripts/cancelAllGhtkShipments.js --dry-run",
    "ghtk:test": "node server/scripts/testGhtkConnection.js",
    "ghn:test": "node server/scripts/testGhnConnection.js",
    "ghn:shops": "node server/scripts/listGhnShops.js",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^1.7.0",
    "mongoose": "^8.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.10",
    "vite": "^8.0.4"
  }
}
