# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/techphone?retryWrites=true&w=majority

# JWT secret
JWT_SECRET=change-me-in-production

# Frontend
VITE_API_BASE_URL=http://localhost:4000

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Admin (sau npm run seed)
ADMIN_EMAIL=admin@techphone.local
ADMIN_PASSWORD=Admin@123456

# Demo fulfillment (tat khi bat GHTK)
FULFILLMENT_DEMO_ENABLED=false

# GHTK
GHTK_ENABLED=true
GHTK_API_TOKEN=your_ghtk_api_token
GHTK_PARTNER_CODE=S123456
GHTK_API_URL=https://services.giaohangtietkiem.vn
GHTK_POLL_ENABLED=true
GHTK_POLL_MS=120000
GHTK_RETRY_MS=300000
GHTK_DEMO_PROGRESS_ENABLED=true
GHTK_DEMO_PROGRESS_MS=30000
GHTK_DEMO_AWAIT_TO_PICKED_MS=120000
GHTK_DEMO_PICKED_TO_SHIPPING_MS=120000
GHTK_DEMO_SHIPPING_TO_COMPLETE_MS=180000
GHTK_PICK_NAME=TechPhone
GHTK_PICK_TEL=0900000000
GHTK_PICK_ADDRESS=123 Duong ABC
GHTK_PICK_PROVINCE=TP. Ho Chi Minh
GHTK_PICK_DISTRICT=Quan 1
GHTK_PICK_WARD=Phuong Ben Nghe

# VNPAY Sandbox
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
API_PUBLIC_URL=http://localhost:4000
