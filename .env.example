# GHN — DEV only (KHONG dung production khi dev)
GHN_ENABLED=true
GHN_API_TOKEN=your_ghn_dev_token
GHN_SHOP_ID=1234567
GHN_API_URL=https://dev-online-gateway.ghn.vn
GHN_POLL_ENABLED=false
GHN_DEMO_PROGRESS_ENABLED=true
GHN_DEMO_PROGRESS_MS=15000
GHN_DEMO_AWAIT_TO_PICKED_MS=60000
GHN_DEMO_PICKED_TO_SHIPPING_MS=60000
GHN_DEMO_SHIPPING_TO_COMPLETE_MS=90000
GHN_RETRY_MS=300000

# Socket.io chat
SOCKET_CORS_ORIGIN=http://localhost:5173
VITE_SOCKET_URL=http://localhost:4000

# Gemini AI chatbox
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
AI_CHAT_RATE_LIMIT=20

# GHTK — legacy, tat
GHTK_ENABLED=false
